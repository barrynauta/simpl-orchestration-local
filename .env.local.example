# =============================================================================
# Simpl Orchestration Platform — Local Environment Configuration
# =============================================================================
# Copy this file to .env.local before running ./start.sh
# (start.sh does this automatically if .env.local is missing)
#
# All hostnames refer to Docker service names — not localhost.
# Do NOT commit .env.local — it may contain credentials.
# =============================================================================

# --- Database (asset-orchestrator) ---
DB_NAME=asset_orchestrator
DB_USER=postgres
DB_PWD=postgres
DB_HOST=postgres
DB_PORT=5432

# --- Application ---
PROJECT_VERSION_NUMBER=local
PROJECT_RELEASE_VERSION=local

# --- Dagster GraphQL ---
# Hostname matches the Docker service name: docker_dagster_webserver
DAGSTER_GRAPHQL_URL=http://docker_dagster_webserver:3000/graphql
DAGSTER_TIMEOUT=30000
DAGSTER_MAX_RETRIES=3

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:19092

# --- Mail (Mailpit) ---
MAIL_HOST=mailpit
MAIL_PORT=1025
EMAIL_FROM=no-reply@simpl-local.eu
EMAIL_FROM_NAME=Asset Orchestrator (Local)
EMAIL_FAIL_ON_ERROR=false

# --- OpenTelemetry (disabled locally by default) ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=asset-orchestrator
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none

# --- Logging ---
SHOW_SQL=false
